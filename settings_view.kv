<SettingsView>:
    orientation: 'vertical'
    
    ScrollView:
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: self.minimum_height
            padding: 0
            spacing: 25

            # Section: Appearance
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: 15
                padding: [20, 20, 20, 20]
                canvas.before:
                    Color:
                        rgba: (1, 1, 1, 1)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [15]
                    Color:
                        rgba: (0, 0, 0, 0.08)
                    RoundedRectangle:
                        pos: (self.pos[0], self.pos[1] - 3)
                        size: (self.size[0], self.size[1] + 6)
                        radius: [15]

                Label:
                    text: "Appearance"
                    font_size: '18sp'
                    size_hint_y: None
                    height: 45
                    color: (0, 0, 0.4, 1)
                    bold: True

                # Color Theme
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: 55
                    spacing: 15
                    Label:
                        text: "Color Theme"
                        size_hint_x: 0.4
                        font_size: '14sp'
                        color: (0, 0, 0, 0.85)
                        halign: 'left'
                        valign: 'middle'
                    Spinner:
                        id: color_spinner
                        text: "Midnight Blue"
                        values: ["Midnight Blue", "Ocean Breeze", "Hot Pink", "Forest Green", "Amber Glow"]
                        size_hint_x: 0.6
                        size_hint_y: None
                        height: 45
                        background_color: (0, 0, 0.4, 1)
                        background_normal: ''
                        color: (1, 1, 1, 1)
                        on_text: root.on_change_color_theme(self.text)

                # Font Size
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: 55
                    spacing: 15
                    Label:
                        text: "Font Size"
                        size_hint_x: 0.4
                        font_size: '14sp'
                        color: (0, 0, 0, 0.85)
                        halign: 'left'
                        valign: 'middle'
                    Spinner:
                        id: size_spinner
                        text: "Medium"
                        values: ["Small", "Medium", "Large"]
                        size_hint_x: 0.6
                        size_hint_y: None
                        height: 45
                        background_color: (0, 0, 0.4, 1)
                        background_normal: ''
                        color: (1, 1, 1, 1)
                        on_text: root.on_change_font_size(self.text)

                # Font Family
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: 55
                    spacing: 15
                    Label:
                        text: "Font Family"
                        size_hint_x: 0.4
                        font_size: '14sp'
                        color: (0, 0, 0, 0.85)
                        halign: 'left'
                        valign: 'middle'
                    Spinner:
                        id: family_spinner
                        text: "Roboto"
                        values: ["Georgia", "Roboto"]
                        size_hint_x: 0.6
                        size_hint_y: None
                        height: 45
                        background_color: (0, 0, 0.4, 1)
                        background_normal: ''
                        color: (1, 1, 1, 1)
                        on_text: root.on_change_font_family(self.text)

                # Sample text to show changes
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: 80
                    padding: [10, 10, 10, 10]
                    canvas.before:
                        Color:
                            rgba: (0.98, 0.96, 0.92, 1)
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [10]
                    Label:
                        id: sample_label
                        text: root.sample_text
                        font_size: root.current_font_size
                        font_name: root.current_font_name
                        size_hint_y: None
                        height: 60
                        color: (0, 0, 0, 0.85)
                        halign: 'center'
                        valign: 'middle'
                        text_size: self.width, None

                # Save Button
                Button:
                    text: "Save"
                    size_hint_y: None
                    height: 50
                    background_normal: ''
                    background_color: (0.2, 0.6, 0.3, 1)
                    canvas.before:
                        Color:
                            rgba: (0.2, 0.6, 0.3, 1)
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [25]
                    color: (1, 1, 1, 1)
                    bold: True
                    on_press: root.on_save_settings()

            # Section: Account
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: 15
                padding: [20, 20, 20, 20]
                canvas.before:
                    Color:
                        rgba: (1, 1, 1, 1)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [15]
                    Color:
                        rgba: (0, 0, 0, 0.08)
                    RoundedRectangle:
                        pos: (self.pos[0], self.pos[1] - 3)
                        size: (self.size[0], self.size[1] + 6)
                        radius: [15]

                Label:
                    text: "Account"
                    font_size: '18sp'
                    size_hint_y: None
                    height: 45
                    color: (0, 0, 0.4, 1)
                    bold: True

                # Student Name
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: 55
                    spacing: 15
                    Label:
                        text: "Student Name"
                        size_hint_x: 0.35
                        font_size: '14sp'
                        color: (0, 0, 0, 0.85)
                        halign: 'left'
                        valign: 'middle'
                    TextInput:
                        id: name_input
                        text: root.student_name
                        size_hint_x: 0.65
                        size_hint_y: None
                        height: 45
                        multiline: False
                        background_color: (0.98, 0.96, 0.92, 1)
                        foreground_color: (0, 0, 0, 0.85)
                        cursor_color: (0.2, 0.4, 0.6, 1)
                        padding: [12, 8, 12, 8]

                # Student ID
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: 55
                    spacing: 15
                    Label:
                        text: "Student ID"
                        size_hint_x: 0.35
                        font_size: '14sp'
                        color: (0, 0, 0, 0.85)
                        halign: 'left'
                        valign: 'middle'
                    TextInput:
                        id: id_input
                        text: root.student_id
                        size_hint_x: 0.65
                        size_hint_y: None
                        height: 45
                        multiline: False
                        background_color: (0.98, 0.96, 0.92, 1)
                        foreground_color: (0, 0, 0, 0.85)
                        cursor_color: (0.2, 0.4, 0.6, 1)
                        padding: [12, 8, 12, 8]

                # Email
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: 55
                    spacing: 15
                    Label:
                        text: "Email"
                        size_hint_x: 0.35
                        font_size: '14sp'
                        color: (0, 0, 0, 0.85)
                        halign: 'left'
                        valign: 'middle'
                    TextInput:
                        id: email_input
                        text: root.student_email
                        size_hint_x: 0.65
                        size_hint_y: None
                        height: 45
                        multiline: False
                        background_color: (0.98, 0.96, 0.92, 1)
                        foreground_color: (0, 0, 0, 0.85)
                        cursor_color: (0.2, 0.4, 0.6, 1)
                        padding: [12, 8, 12, 8]

                # Academic Year
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: 55
                    spacing: 15
                    Label:
                        text: "Academic Year"
                        size_hint_x: 0.35
                        font_size: '14sp'
                        color: (0, 0, 0, 0.85)
                        halign: 'left'
                        valign: 'middle'
                    Spinner:
                        id: year_spinner
                        text: root.academic_year
                        values: ["Freshman", "Sophomore", "Junior", "Senior"]
                        size_hint_x: 0.65
                        size_hint_y: None
                        height: 45
                        background_color: (0, 0, 0.4, 1)
                        background_normal: ''
                        color: (1, 1, 1, 1)

                # Save Account Button
                Button:
                    text: "Save"
                    size_hint_y: None
                    height: 50
                    background_normal: ''
                    background_color: (0.2, 0.6, 0.3, 1)
                    canvas.before:
                        Color:
                            rgba: (0.2, 0.4, 0.6, 1)
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [25]
                    color: (1, 1, 1, 1)
                    bold: True
                    on_press: root.on_save_account_settings()

                Image:
                    source: 'USM 5.jpg'
                    size_hint_x: 1
                    size_hint_y: None
                    height: self.texture.height / self.texture.width * self.width if self.texture else 150
                    allow_stretch: True
                    keep_ratio: True

            