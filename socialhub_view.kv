                            size_hint_y: None
                            height: 38
                            background_normal: ''
                            background_color: (0, 0, 0.4, 1)
                            canvas.before:
                                Color:
                                    rgba: (0.2, 0.4, 0.6, 1)
                                RoundedRectangle:
