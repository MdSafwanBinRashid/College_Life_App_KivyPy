<SocialHubView>:
    orientation: 'vertical'
    
    ScrollView:
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: self.minimum_height
            padding: 0
            spacing: 40

            # Section: Upcoming Campus Events
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: 40
                padding: [20, 20, 20, 20]
                canvas.before:
                    Color:
                        rgba: (1, 1, 1, 1)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [15]
                    Color:
                        rgba: (0, 0, 0, 0.08)
                    RoundedRectangle:
                        pos: (self.pos[0], self.pos[1] - 3)
                        size: (self.size[0], self.size[1] + 6)
                        radius: [15]

                Label:
                    text: "Upcoming Campus Events"
                    font_size: '18sp'
                    size_hint_y: None
                    height: 45
                    color: (0, 0, 0.4, 1)
                    bold: True

                Image:
                    source: 'USM 12.jpg'
                    size_hint_x: 1
                    size_hint_y: None
                    height: 250
                    allow_stretch: True
                    keep_ratio: False
                    fit_mode: 'cover'

                # Event 1: Career Fair
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: 155
                    spacing: 15
                    padding: [15, 15, 15, 15]
                    canvas.before:
                        Color:
                            rgba: (0.98, 0.96, 0.92, 1)
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [12]
                    
                    Label:
                        text: "Feb 15"
                        size_hint_x: 0.2
                        font_size: '15sp'
                        color: (0, 0, 0.4, 1)
                        bold: True
                        halign: 'center'
                        valign: 'middle'
                    
                    BoxLayout:
                        orientation: 'vertical'
                        size_hint_x: 0.8
                        spacing: 6
                        Label:
                            text: "Career Fair 2026"
                            font_size: '15sp'
                            color: (0, 0, 0, 0.85)
                            bold: True
                            halign: 'left'
                            size_hint_y: None
                            height: 28
                        Label:
                            text: "RC Cook Union"
                            font_size: '12sp'
                            color: (0.5, 0.5, 0.5, 1)
                            halign: 'left'
                            size_hint_y: None
                            height: 22
                        Label:
                            text: "10:00 AM - 4:00 PM"
                            font_size: '12sp'
                            color: (0.5, 0.5, 0.5, 1)
                            halign: 'left'
                            size_hint_y: None
                            height: 22
                        Button:
                            text: "Add to Calendar"
                            size_hint_y: None
                            height: 38
                            background_normal: ''
                            background_color: (0, 0, 0.4, 1)
                            canvas.before:
                                Color:
                                    rgba: (0.2, 0.4, 0.6, 1)
                                RoundedRectangle:
                                    pos: self.pos
                                    size: self.size
                                    radius: [19]
                            color: (1, 1, 1, 1)
                            bold: True
                            on_press: root.on_add_to_calendar("Career Fair 2026")

                Image:
                    source: 'USM 2.jpg'
                    size_hint_x: 1
                    size_hint_y: None
                    height: 250
                    allow_stretch: True
                    keep_ratio: False
                    fit_mode: 'cover'

                # Event 2: Basketball Game
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: 155
                    spacing: 15
                    padding: [15, 15, 15, 15]
                    canvas.before:
                        Color:
                            rgba: (0.98, 0.96, 0.92, 1)
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [12]

                    Label:
                        text: "Feb 20"
                        size_hint_x: 0.2
                        font_size: '15sp'
                        color: (0, 0, 0.4, 1)
                        bold: True
                        halign: 'center'
                        valign: 'middle'
                    
                    BoxLayout:
                        orientation: 'vertical'
                        size_hint_x: 0.8
                        spacing: 6
                        Label:
                            text: "Basketball Game: Uni vs State"
                            font_size: '15sp'
                            color: (0, 0, 0, 0.85)
                            bold: True
                            halign: 'left'
                            size_hint_y: None
                            height: 28
                        Label:
                            text: "Rock Arena"
                            font_size: '12sp'
                            color: (0.5, 0.5, 0.5, 1)
                            halign: 'left'
                            size_hint_y: None
                            height: 22
                        Label:
                            text: "11:00 AM - 1:00 PM"
                            font_size: '12sp'
                            color: (0.5, 0.5, 0.5, 1)
                            halign: 'left'
                            size_hint_y: None
                            height: 22
                        Button:
                            text: "Add to Calendar"
                            size_hint_y: None
                            height: 38
                            background_normal: ''
                            background_color: (0, 0, 0.4, 1)
                            canvas.before:
                                Color:
                                    rgba: (0.2, 0.4, 0.6, 1)
                                RoundedRectangle:
                                    pos: self.pos
                                    size: self.size
                                    radius: [19]
                            color: (1, 1, 1, 1)
                            bold: True
                            on_press: root.on_add_to_calendar("Basketball Game: University vs State")

                Image:
                    source: 'USM 15.jpg'
                    size_hint_x: 1
                    size_hint_y: None
                    height: 250
                    allow_stretch: True
                    keep_ratio: False
                    fit_mode: 'cover'

                # Event 3: Study Abroad
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: 155
                    spacing: 15
                    padding: [15, 15, 15, 15]
