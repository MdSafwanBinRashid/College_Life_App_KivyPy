                            bold: True
                            halign: 'left'
                            size_hint_y: None
                            height: 28
                        Label:
                            text: "International Center"
                            font_size: '12sp'
                            color: (0.5, 0.5, 0.5, 1)
                            halign: 'left'
                            size_hint_y: None
