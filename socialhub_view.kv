                Image:
                    source: 'USM 21.jpg'
                    size_hint_x: 1
                    size_hint_y: None
                    height: 250
                    allow_stretch: True
                    keep_ratio: False
                    fit_mode: 'cover'

                # Event 4: Movie Night
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: 155
                    spacing: 15
