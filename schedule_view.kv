<ScheduleView>:
    orientation: 'vertical'
    
    ScrollView:
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: self.minimum_height
            padding: 15
            spacing: 15

            Image:
                source: 'USM 20.jpg'
                size_hint_x: 1
                size_hint_y: None
                height: 250
                allow_stretch: True
                keep_ratio: False
                fit_mode: 'cover'

            # Add New Class Section
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: 15
                padding: [15, 15, 15, 15]
                canvas.before:
                    Color:
                        rgba: (1, 1, 1, 1)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [15]
                    Color:
                        rgba: (0, 0, 0, 0.08)
                    RoundedRectangle:
                        pos: (self.pos[0], self.pos[1] - 3)
                        size: (self.size[0], self.size[1] + 6)
                        radius: [15]

                Label:
                    text: "Add New Class"
                    font_size: '18sp'
                    size_hint_y: None
                    height: 45
                    halign: 'center'
                    color: (0, 0, 0.4, 1)
                    bold: True

                TextInput:
                    id: course_input
                    hint_text: "Course Code"
                    size_hint_y: None
                    height: 50
                    multiline: False
                    background_color: (0.98, 0.96, 0.92, 1)
                    foreground_color: (0, 0, 0, 0.85)
                    cursor_color: (0.2, 0.4, 0.6, 1)
                    padding: [15, 10, 15, 10]

                TextInput:
                    id: day_input
                    hint_text: "Day (Monday, Tuesday, etc.)"
                    size_hint_y: None
                    height: 50
                    multiline: False
                    background_color: (0.98, 0.96, 0.92, 1)
                    foreground_color: (0, 0, 0, 0.85)
                    cursor_color: (0.2, 0.4, 0.6, 1)
                    padding: [15, 10, 15, 10]

                TextInput:
                    id: time_input
                    hint_text: "Time (e.g., 10:00 - 11:30 AM)"
                    size_hint_y: None
                    height: 50
                    multiline: False
                    background_color: (0.98, 0.96, 0.92, 1)
                    foreground_color: (0, 0, 0, 0.85)
                    cursor_color: (0.2, 0.4, 0.6, 1)
                    padding: [15, 10, 15, 10]

                Button:
                    text: "Add Class"
                    size_hint_y: None
                    height: 50
                    background_normal: ''
                    background_color: (0.2, 0.6, 0.3, 1)
                    canvas.before:
                        Color:
                            rgba: (0.2, 0.6, 0.3, 1)
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [25]
                        Color:
                            rgba: (0.3, 0.7, 0.4, 0.5)
                        RoundedRectangle:
                            pos: (self.pos[0], self.pos[1] + self.size[1] * 0.5)
                            size: (self.size[0], self.size[1] * 0.3)
                            radius: [25]
                    color: (1, 1, 1, 1)
                    bold: True
                    on_press: root.on_add_class()

            # Weekly Schedule Section
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: 15
                padding: [15, 15, 15, 15]
                canvas.before:
                    Color:
                        rgba: (1, 1, 1, 1)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [15]
                    Color:
                        rgba: (0, 0, 0, 0.08)
                    RoundedRectangle:
                        pos: (self.pos[0], self.pos[1] - 3)
                        size: (self.size[0], self.size[1] + 6)
                        radius: [15]

                Label:
                    text: "Weekly Schedule"
                    font_size: '18sp'
                    size_hint_y: None
                    height: 45
                    halign: 'center'
                    color: (0, 0, 0.4, 1)
                    bold: True

                GridLayout:
                    id: schedule_list
                    cols: 1
                    size_hint_y: None
                    height: self.minimum_height
                    spacing: 15
                    padding: [5, 5, 5, 5]