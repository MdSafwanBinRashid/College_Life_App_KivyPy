<FlashcardView>:
    orientation: 'vertical'
    
    ScrollView:
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: self.minimum_height
            padding: 0
            spacing: 25

            # Section 1: Flashcards
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: 20
                padding: [15, 15, 15, 15]
                canvas.before:
                    Color:
                        rgba: (1, 1, 1, 1)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [15]
                    Color:
                        rgba: (0, 0, 0, 0.08)
                    RoundedRectangle:
                        pos: (self.pos[0], self.pos[1] - 3)
                        size: (self.size[0], self.size[1] + 6)
                        radius: [15]

                Label:
                    text: "Flashcards"
                    font_size: '20sp'
                    size_hint_y: None
                    height: 45
                    color: (0, 0, 0.4, 1)
                    bold: True
                    halign: 'center'

                # Flashcard Card
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: 220
                    spacing: 15
                    padding: [25, 25, 25, 25]
                    canvas.before:
                        Color:
                            rgba: (0.98, 0.96, 0.92, 1)
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [20]
                        Color:
                            rgba: (1, 1, 1, 0.3)
                        RoundedRectangle:
                            pos: (self.pos[0], self.pos[1] + self.size[1] * 0.7)
                            size: (self.size[0], self.size[1] * 0.3)
                            radius: [20]
                        Color:
                            rgba: (0.2, 0.4, 0.6, 0.3)
                        Line:
                            rounded_rectangle: (self.pos[0], self.pos[1], self.size[0], self.size[1], 20)

                    Label:
                        id: card_content
                        text: root.current_question if not root.is_flipped else root.current_answer
                        font_size: '18sp'
                        color: (0, 0, 0, 0.85)
                        halign: 'center'
                        valign: 'middle'
                        size_hint_y: 1
                        text_size: self.width, None

                # Flip Button
                Button:
                    text: "Flip Card"
                    size_hint_y: None
                    height: 50
                    background_normal: ''
                    background_color: (0, 0, 0.4, 1)
                    canvas.before:
                        Color:
                            rgba: (0.2, 0.4, 0.6, 1)
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [25]
                        Color:
                            rgba: (0.3, 0.5, 0.7, 0.5)
                        RoundedRectangle:
                            pos: (self.pos[0], self.pos[1] + self.size[1] * 0.5)
                            size: (self.size[0], self.size[1] * 0.3)
                            radius: [60]
                    color: (1, 1, 1, 1)
                    bold: True
                    on_press: root.on_flip_card()

                # Previous / Next Buttons
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: 50
                    spacing: 15

                    Button:
                        text: "Previous"
                        on_press: root.on_previous_card()
                        disabled: root.current_index == 0
                        background_normal: ''
                        background_color: (0.5, 0.5, 0.5, 1) if root.current_index == 0 else (0.3, 0.3, 0.3, 1)
                        canvas.before:
                            Color:
                                rgba: self.background_color
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [0]
                        color: (1, 1, 1, 1)
                        bold: True

                    Button:
                        text: "Next"
                        on_press: root.on_next_card()
                        disabled: root.current_index == root.total_cards - 1
                        background_normal: ''
                        background_color: (0.5, 0.5, 0.5, 1) if root.current_index == root.total_cards - 1 else (0.3, 0.3, 0.3, 1)
                        canvas.before:
                            Color:
                                rgba: self.background_color
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [0]
                        color: (1, 1, 1, 1)
                        bold: True

            # Section 2: Create New Flashcard
            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                spacing: 15
                padding: [15, 15, 15, 15]
                canvas.before:
                    Color:
                        rgba: (1, 1, 1, 1)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [15]
                    Color:
                        rgba: (0, 0, 0, 0.08)
                    RoundedRectangle:
                        pos: (self.pos[0], self.pos[1] - 3)
                        size: (self.size[0], self.size[1] + 6)
                        radius: [15]

                Label:
                    text: "+ Create New Flashcard"
                    font_size: '20sp'
                    size_hint_y: None
                    height: 45
                    color: (0, 0, 0.4, 1)
                    bold: True
                    halign: 'center'

                TextInput:
                    id: new_question
                    hint_text: "Enter question"
                    size_hint_y: None
                    height: 55
                    multiline: False
                    background_color: (0.98, 0.96, 0.92, 1)
                    foreground_color: (0, 0, 0, 0.85)
                    cursor_color: (0.2, 0.4, 0.6, 1)
                    padding: [15, 10, 15, 10]

                TextInput:
                    id: new_answer
                    hint_text: "Enter answer"
                    size_hint_y: None
                    height: 55
                    multiline: False
                    background_color: (0.98, 0.96, 0.92, 1)
                    foreground_color: (0, 0, 0, 0.85)
                    cursor_color: (0.2, 0.4, 0.6, 1)
                    padding: [15, 10, 15, 10]

                Button:
                    text: "Create"
                    size_hint_y: None
                    height: 50
                    background_normal: ''
                    background_color: (0.2, 0.6, 0.3, 1)
                    canvas.before:
                        Color:
                            rgba: (0.2, 0.6, 0.3, 1)
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [25]
                        Color:
                            rgba: (0.3, 0.7, 0.4, 0.5)
                        RoundedRectangle:
                            pos: (self.pos[0], self.pos[1] + self.size[1] * 0.5)
                            size: (self.size[0], self.size[1] * 0.3)
                            radius: [25]
                    color: (1, 1, 1, 1)
                    bold: True
                    on_press: root.on_add_card()

                # Delete Button
                Button:
                    text: "Delete Card"
                    size_hint_y: None
                    height: 50
                    background_normal: ''
                    background_color: (0.8, 0.2, 0.2, 1)
                    canvas.before:
                        Color:
                            rgba: (0.8, 0.2, 0.2, 1)
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [25]
                    color: (1, 1, 1, 1)
                    bold: True
                    on_press: root.on_delete_card()
                    disabled: root.total_cards == 0

                Image:
                    source: 'FL 1.jpg'
                    size_hint_x: 1
                    size_hint_y: None
                    height: 320
                    allow_stretch: True
                    keep_ratio: False
                    fit_mode: 'cover'

            # Bottom spacer
            Widget:
                size_hint_y: None
                height: 10